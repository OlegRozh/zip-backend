# App
APP_ENV=dev
APP_PORT=8080
APP_FRONTEND_URL=http://localhost:3000
CONFIG_PATH=config/config.dev.yml

# PostgreSQL
DB_URL=postgres://linka:linka@localhost:5432/linka?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# NATS
NATS_CONNECTION_URL=nats://localhost:4222

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=linka-media
MINIO_USE_SSL=false
MINIO_TIMEOUT=15s

# JWT
JWT_SECRET=changeme-min-32-chars-secret-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Crypto
CRYPTO_AES_KEY=01234567890123456789012345678901
CRYPTO_HMAC_KEY=abcdefghijklmnopqrstuvwxyz123456

# Yandex OAuth2
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URL=http://localhost:8080/auth/yandex/callback

# Pictures Bank
PICTURES_BANK_URL=
PICTURES_BANK_TOKEN=

# OpenAI
OPENAI_API_KEY=

# Yandex SpeechKit
YANDEX_IAM_TOKEN=
YANDEX_FOLDER_ID=

# Grafana
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000

# SMTP
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_FROM_EMAIL=noreply@yandex.com
SMTP_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=

